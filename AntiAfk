-- Pulse animation for status dot
task.spawn(function()
    while screenGui and screenGui.Parent do
        local tweenDown = TweenService:Create(statusDot, TweenInfo.new(0.9, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
            BackgroundColor3 = Color3.fromRGB(40, 160, 80),
        })
        tweenDown:Play()
        task.wait(0.9)

        local tweenUp = TweenService:Create(statusDot, TweenInfo.new(0.9, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
            BackgroundColor3 = Color3.fromRGB(80, 220, 120),
        })
        tweenUp:Play()
        task.wait(0.9)
    end
end)

