-- Real FPS counter
task.spawn(function()
    local lastTick = tick()
    local frameCount = 0
    while screenGui and screenGui.Parent do
        frameCount = frameCount + 1
        local now = tick()
        if now - lastTick >= 1 then
            fpsValue.Text = tostring(frameCount)
            frameCount = 0
            lastTick = now
        end
        RunService.RenderStepped:Wait()
    end
end)

-- Real Ping
task.spawn(function()
    while screenGui and screenGui.Parent do
        local pingMs = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
        pingValue.Text = tostring(pingMs)
        task.wait(1)
    end
end)

-- Timer
genv.timerRunning = true

task.spawn(function()
    local elapsed = 0
    while genv.timerRunning do
        task.wait(1)
        elapsed = elapsed + 1
        local hours = math.floor(elapsed / 3600)
        local minutes = math.floor((elapsed % 3600) / 60)
        local seconds = elapsed % 60
        timerValue.Text = string.format("%d:%d:%d", hours, minutes, seconds)
    end
end)
